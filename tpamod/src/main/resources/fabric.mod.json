{
  "schemaVersion": 1,
  "id": "tpamod",
  "version": "${version}",
  "name": "TPA Mod",
  "description": "This mod allows players to teleport to one another and easily return to their previous locations. It also features a death teleport, letting players return instantly to where they last died.",
  "authors": ["AyushGerra"],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "environment": "*",
  "entrypoints": {
    "main": ["com.example.TpaMod"]
  },
  "mixins": ["tpamod.mixins.json"],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": ">=26.1",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
