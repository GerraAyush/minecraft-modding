{
	"schemaVersion": 1,
	"id": "tutorial",
	"version": "${version}",
	"name": "Example Mod",
	"description": "This is tutorial mod!",
	"authors": [
		"AyushGerra"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/tutorial/icon.png",
	"environment": "*",
